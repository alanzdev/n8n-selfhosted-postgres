# =========================
# n8n - Configurações Gerais
# =========================
# Chave usada para criptografar credenciais e dados sensíveis no n8n.
# IMPORTANTE:
# - Deve ser uma string longa e aleatória
# - NÃO altere após o n8n já estar em uso (perda de credenciais)
N8N_ENCRYPTION_KEY="CHANGE-ME"
# Host público onde o n8n será acessado (domínio ou IP).
# Exemplo: n8n.exemplo.com
N8N_HOST="CHANGE-ME"

# =========================
# SSL / HTTPS
# =========================
# Caminho completo, dentro do container, para o certificado SSL (fullchain).
# Exemplo: /certs/fullchain.pem
N8N_SSL_CERT="CHANGE-ME"
# Caminho completo, dentro do container, para a chave privada do certificado SSL.
# Exemplo: /certs/privkey.pem
N8N_SSL_KEY="CHANGE-ME"

# Volume Docker que monta os certificados SSL dentro do container.
# Formato: /caminho/no/host:/caminho/no/container:ro
# Exemplo: /etc/letsencrypt:/certs:ro
CERT_VOLUMES="CHANGE-ME"

# =========================
# PostgreSQL
# =========================
# Nome do banco de dados utilizado pelo n8n.
POSTGRES_DATABASE="CHANGE-ME"
# Usuário do banco de dados PostgreSQL.
POSTGRES_USER="CHANGE-ME"
# Senha do usuário PostgreSQL.
POSTGRES_PASSWORD="CHANGE-ME"